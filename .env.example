# Copy to .env.local and fill in values from your Supabase project:
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose to the browser or commit real values.
# Use only in trusted server code (webhooks, cron). Prefer RLS + anon key for app routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (Phase 1 invites / Phase 2 digests)
RESEND_API_KEY=
EMAIL_FROM=TeamOS <noreply@yourdomain.com>

# App URL used in invite links
NEXT_PUBLIC_APP_URL=http://localhost:3000
